{
    // 明确指定需要检查的目录（只写核心代码目录，比如 src、项目根目录）
    "include": [
        "./core" // 你的核心代码目录（替换成实际路径）
    ],
    // 排除不需要扫描的目录/文件（重点！减少扫描量）
    "exclude": [
        // 通用排除项（建议保留）
        "**/__pycache__",
        "**/.git",
        "**/.vscode",
        "**/.lingma",
        "**/.apsara-apm",
        "**/node_modules",
        "**/.venv",
        "**/.env",
        // 自定义排除项（根据你的项目补充）
        "**/data", // 大数据文件目录
        "**/logs", // 日志目录
        "**/temp", // 临时文件目录
        "**/data" 
    ],
    // 可选：关闭不必要的检查，进一步提速
    "typeCheckingMode": "basic" // 可选："off"（最快）、"basic"（基础检查）、"strict"（严格检查）
}